# Mac 本地调试环境配置
# 将 <SERVER_IP> 替换为你的服务器实际 IP（运行 Milvus/Redis/vLLM 的机器）

# LLM（指向服务器上的 vLLM）
LLM_PROVIDER=vllm
VLLM_BASE_URL=http://<SERVER_IP>:8000/v1
VLLM_MODEL=Qwen2.5-72B-Instruct

# 云端备选（本地调试时可临时切换，避免依赖 vLLM 服务器）
# LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# Milvus（服务器 IP）
MILVUS_HOST=<SERVER_IP>
MILVUS_PORT=19530
MILVUS_COLLECTION=book_see_rag

# Redis（服务器 IP）
REDIS_URL=redis://<SERVER_IP>:6379/0
SESSION_TTL=86400

# Embedding & Reranker
# Mac 上用 CPU（无 CUDA），Apple Silicon 可改为 mps
EMBED_MODEL=BAAI/bge-large-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BGE_DEVICE=cpu
RERANK_TOP_N=50
RERANK_TOP_K=10

# OCR（Mac 上用 CPU）
MARKER_DEVICE=cpu

# 存储（本地路径）
UPLOAD_DIR=./data/uploads

# API
API_HOST=0.0.0.0
API_PORT=8000
