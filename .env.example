# LLM Provider
LLM_PROVIDER=vllm            # vllm | claude | openai

# vLLM（本地两张 4090，启动时加 --tensor-parallel-size 2）
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen2.5-72B-Instruct

# 云端备选
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# Milvus
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION=book_see_rag

# Embedding & Reranker（本地 GPU）
EMBED_MODEL=BAAI/bge-large-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BGE_DEVICE=cuda
RERANK_TOP_N=50
RERANK_TOP_K=10

# Redis（对话记忆 + Celery broker）
REDIS_URL=redis://redis:6379/0
SESSION_TTL=86400

# OCR
MARKER_DEVICE=cuda           # cuda | cpu

# 存储
UPLOAD_DIR=/app/data/uploads

# API
API_HOST=0.0.0.0
API_PORT=8000
